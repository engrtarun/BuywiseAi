# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================================================================
# STRICT RULE: DO NOT COMMIT ANY .ENV FILES!
# =========================================================================
# Environment variables contain sensitive secrets (API keys, etc.).
# NEVER remove this rule. Committing .env files is a security risk and 
# will be blocked by GitHub Push Protection.
# For Netlify deployments, add your Environment Variables directly in the 
# Netlify Dashboard (Site Settings > Environment Variables), NOT in code!
# =========================================================================
.env
.env.*
!.env.example

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

